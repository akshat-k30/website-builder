generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdGroups   Group[]          @relation("GroupCreator")
  memberships     GroupMember[]
  linkedinProfile LinkedInProfile?
  website         Website?
}

model Group {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String   @default("")
  inviteCode  String   @unique
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy GroupMember[] @relation("GroupMembers")
  creator   User         @relation("GroupCreator", fields: [createdById], references: [id])
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  group Group @relation("GroupMembers", fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model LinkedInProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  linkedinUrl     String?
  rawText         String   @default("")
  parsedName      String   @default("")
  parsedHeadline  String   @default("")
  parsedLocation  String   @default("")
  parsedSummary   String   @default("")
  parsedExperience String  @default("[]")
  parsedEducation  String  @default("[]")
  parsedSkills     String  @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Website {
  id                 String    @id @default(uuid())
  userId             String    @unique
  aiGeneratedContent String    @default("{}")
  userEditedContent  String?
  templateId         String?
  themeSettings      String    @default("{}")
  subdomain          String?   @unique
  publishedUrl       String?
  publishedAt        DateTime?
  status             String    @default("draft")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
